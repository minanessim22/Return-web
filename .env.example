# Core app URL used when generating public QR links
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── Database Connection (Supabase PostgreSQL / Prisma) ──
# Pooled URL — used for all runtime queries (via PgBouncer / Transaction Pooler)
#   - Port 6543 = Supabase transaction pooler (PgBouncer)
#   - pgbouncer=true   → tells Prisma to use PgBouncer-compatible mode
#   - connection_limit=1 → prevents serverless functions from hogging connections
#   - connect_timeout=15 → avoids Vercel timeout hangs if DB is unreachable
DATABASE_URL="postgresql://postgres.PROJECT:PASSWORD@aws-1-REGION.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1&connect_timeout=15"

# Direct URL — used ONLY for migrations and schema pushes (bypasses PgBouncer)
#   - Port 5432 = direct Postgres connection
#   - Required by `prisma migrate dev` and `prisma db push`
DIRECT_URL="postgresql://postgres.PROJECT:PASSWORD@aws-1-REGION.pooler.supabase.com:5432/postgres"

# Supabase Client configuration
NEXT_PUBLIC_SUPABASE_URL=https://your-supabase-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-supabase-anon-key

# Real email delivery (SMTP)
EMAIL_FROM=RETURN <noreply@example.com>
EMAIL_SMTP_HOST=smtp.example.com
EMAIL_SMTP_PORT=587
EMAIL_SMTP_SECURE=false
EMAIL_SMTP_USER=smtp-user@example.com
EMAIL_SMTP_PASS=your-smtp-password

# Optional production email delivery using Resend
RESEND_API_KEY=your-resend-api-key

# Legacy NextAuth values kept for compatibility with the original frontend route
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=replace-with-a-long-random-secret

# Kairos face matching for backend AI comparisons
KAIROS_APP_ID=362479e4
KAIROS_APP_KEY=4525c8e25bd6a5fe8a66c5924e11c1dc

# ── MQTT Configuration for AI-Thinker A9G Hardware ──
# MQTT broker URL for GPS tracking device telemetry
MQTT_BROKER_URL=wss://broker.hivemq.com:8884/mqtt
# MQTT topic pattern to subscribe to (device_id is wildcarded)
MQTT_TOPIC=return/tracker/+/location
# Optional: MQTT client ID (auto-generated if not set)
MQTT_CLIENT_ID=return-server
# Optional: MQTT authentication credentials (if broker requires them)
MQTT_USERNAME=
MQTT_PASSWORD=

# ── Production Hardening Configuration ──
# Admin Seed Credentials
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-me-in-production

# Vercel Cron Session Cleanup Secret
CRON_SECRET=your-cron-secret-key

# Upstash Redis Rate Limiting (Optional, falls back to in-memory)
UPSTASH_REDIS_REST_URL=https://your-upstash-redis.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-redis-token

# Prisma Debug Mode (set to 'true' to enable query logging)
DEBUG_PRISMA=false

# ── Sentry Observability Configuration (Optional) ──
# DSN format: https://publicKey@host/projectId
SENTRY_DSN=
# Auth token used for uploading source maps (only required during production build)
SENTRY_AUTH_TOKEN=
